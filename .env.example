# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-supabase-secret-key  # sb_secret_... from Supabase dashboard

# App URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Polar Billing (Supabase adapter)
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_IS_SANDBOX=true
POLAR_PRO_PRODUCT_ID=your-pro-product-id
POLAR_UNLIMITED_PRODUCT_ID=your-unlimited-product-id

# PostHog Analytics
# Use your PostHog project API key (starts with phc_) for both client + server capture
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://us.i.posthog.com

# Trigger.dev (for running scan tasks without timeouts)
# Get this from: https://cloud.trigger.dev → project → API keys
TRIGGER_SECRET_KEY=tr_dev_...

# Support forms (replace mailto links in Settings > Support)
# Example values: Tally embed/share URL, Formspree form URL, etc.
NEXT_PUBLIC_SUPPORT_FORM_URL=
NEXT_PUBLIC_FEATURE_REQUEST_FORM_URL=

# Phased Security Scanning (OSINT + DAST)
# Feature toggles (set to true/false)
SHIPGUARD_PHASE_OSINT=false
SHIPGUARD_PHASE_DAST=true

# DAST safe probe target (staging URL) and optional auth header
# Example URL: https://staging.yourapp.com
# Source: Your staging deployment URL (Vercel/Netlify/Fly/etc)
SHIPGUARD_DAST_STAGING_URL=
# Example header value: Bearer eyJhbGciOi...
# Source: A staging-only bearer token or API key your middleware accepts.
# Create a dedicated low-privilege token for automated probes.
SHIPGUARD_DAST_AUTH_HEADER=

# Optional OSINT provider keys
# SHODAN_API_KEY source: https://account.shodan.io/
SHODAN_API_KEY=
# Censys sources: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=
